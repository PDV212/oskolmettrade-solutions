# Hashed build assets (Vite content hash) — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Deployment manifest — must NEVER be cached. Consumed by the runtime
# update watcher (src/lib/appVersion.ts) to detect newer deployments.
/version.json
  Cache-Control: no-store, max-age=0
/deploy-version.json
  Cache-Control: no-store, max-age=0

# SPA route HTML — the entry document must always revalidate so returning
# visitors pick up a new deployment on the next normal reload.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/en
  Cache-Control: public, max-age=0, must-revalidate
/zh
  Cache-Control: public, max-age=0, must-revalidate
/en/*
  Cache-Control: public, max-age=0, must-revalidate
/zh/*
  Cache-Control: public, max-age=0, must-revalidate
/about
  Cache-Control: public, max-age=0, must-revalidate
/cases
  Cache-Control: public, max-age=0, must-revalidate
/company
  Cache-Control: public, max-age=0, must-revalidate
/cnc-machines
  Cache-Control: public, max-age=0, must-revalidate
/ferroalloys
  Cache-Control: public, max-age=0, must-revalidate

  
# Кеширование изображений
*.jpg
  Cache-Control: public, max-age=2592000
*.jpeg
  Cache-Control: public, max-age=2592000
*.png
  Cache-Control: public, max-age=2592000
*.webp
  Cache-Control: public, max-age=2592000
*.avif
  Cache-Control: public, max-age=2592000
*.svg
  Cache-Control: public, max-age=2592000
*.ico
  Cache-Control: public, max-age=31536000

# Кеширование шрифтов
*.woff
  Cache-Control: public, max-age=31536000, immutable
*.woff2
  Cache-Control: public, max-age=31536000, immutable
*.ttf
  Cache-Control: public, max-age=31536000, immutable

# HTML файлы - без кеширования для обновлений
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  
# Service Worker
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Uploads
/lovable-uploads/*
  Cache-Control: public, max-age=2592000
  
# Security headers
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin