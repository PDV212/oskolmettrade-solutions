<IfModule mod_headers.c>
    # ---- Cache policy ----
    # Deployment manifest — never cache; the client polls it to detect updates.
    <FilesMatch "^(version|deploy-version)\.json$">
        Header set Cache-Control "no-store, max-age=0"
    </FilesMatch>

    # Kill-switch Service Worker — never cache.
    <FilesMatch "^sw\.js$">
        Header set Cache-Control "no-store, max-age=0"
    </FilesMatch>

    # HTML entry document — always revalidate so returning visitors get
    # the current build on a normal reload.
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>

    # Content-hashed build assets — safe to cache forever.
    <FilesMatch "^assets/.*\.(js|css|woff2?|ttf|jpg|jpeg|png|webp|avif|svg|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Exact permanent redirect: /ru/company is a duplicate alias of /company.
RewriteRule ^ru/company/?$ /company [R=301,L]

# Send Cache-Control on extension-less SPA route HTML too.
<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/(en|zh)?/?(about|company|cases|cnc-machines|ferroalloys|faq)?/?$#">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </If>
</IfModule>

# SPA fallback: serve index.html for non-file, non-directory requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
</IfModule>

